<https://ogcincubator.github.io/bblocks-prez/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - Prez OGC Blocks" ;
    dct:abstract """OGC Blocks for working with the [Prez](https://github.com/RDFLib/prez) application.
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:description """This collection provides OGC Building Blocks for working with [Prez](https://github.com/RDFLib/prez),
a read-only linked data API and browser built on SPARQL.

Building blocks in this collection define JSON input formats and semantic uplift pipelines that
transform structured JSON documents into RDF graphs ready for publication via Prez. They rely on
standard vocabularies — primarily DCAT and SKOS — and follow OGC patterns for schema definition,
validation (JSON Schema + SHACL), and semantic uplift (jq + SPARQL).
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-04-17T11:53:43.802084"^^xsd:dateTime ;
    owl:imports <https://opengeospatial.github.io/bblocks/register.json> ;
    skos:hasTopConcept <bblocks://ogc.prez.hierarchy.default> ;
    skos:prefLabel "Building Blocks - Prez OGC Blocks" ;
    prof:hasResource [ rdfs:label "This Building Blocks Register in JSON-LD format" ;
            dct:type "application/ld+json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/bblocks-prez/build/bblocks.jsonld> ],
        [ rdfs:label "This Building Blocks Register in RDF Turtle format" ;
            dct:type "text/turtle" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/bblocks-prez/build/bblocks.ttl> ],
        [ rdfs:label "This Building Blocks Register in JSON format" ;
            dct:type "application/json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/bblocks-prez/build/register.json> ] ;
    foaf:homepage <https://ogcincubator.github.io/bblocks-prez/> ;
    bblocks:hasValidationReport <https://ogcincubator.github.io/bblocks-prez/build/tests/report.html> .

